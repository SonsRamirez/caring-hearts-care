---
/** ServiceCard — photo-topped or icon-medallion service card. Links to `href` when
 *  provided; otherwise renders as a plain (non-linking) card, matching the live site
 *  which has no per-service detail pages. */
import Icon from './Icon.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  image?: string;
  href?: string;
}
const { icon, title, description, image, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

{image ? (
  <Tag class="card card--lift service service--photo" {...(href ? { href } : {})}>
    <div class="service__photo" style={`background-image:url(${image})`}>
      <span class="service__medal service__medal--onphoto"><Icon name={icon} /></span>
    </div>
    <div class="service__body">
      <h3 class="service__title">{title}</h3>
      <p class="service__desc">{description}</p>
      {href && <span class="service__link">Learn more<Icon name="arrow-right" /></span>}
    </div>
  </Tag>
) : (
  <Tag class="card card--lift service" {...(href ? { href } : {})}>
    <div class="service__medal"><Icon name={icon} /></div>
    <h3 class="service__title">{title}</h3>
    <p class="service__desc">{description}</p>
    {href && <span class="service__link">Learn more<Icon name="arrow-right" /></span>}
  </Tag>
)}
