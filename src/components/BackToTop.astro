---
/** BackToTop — floating button that appears after scrolling and returns to the top. */
import Icon from './Icon.astro';
---

<button id="back-to-top" class="back-to-top" aria-label="Back to top" hidden>
  <Icon name="arrow-up" />
</button>

<style>
  .back-to-top {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 60;
    width: 48px;
    height: 48px;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--chc-gold);
    color: var(--chc-navy);
    box-shadow: var(--shadow-gold);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out),
      background var(--duration-base);
  }
  .back-to-top.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .back-to-top:hover {
    background: var(--chc-gold-deep);
  }
  .back-to-top:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }
  .back-to-top :global(svg) {
    width: 22px;
    height: 22px;
  }
  @media (prefers-reduced-motion: reduce) {
    .back-to-top { transition: opacity var(--duration-base) linear; transform: none; }
    .back-to-top.is-visible { transform: none; }
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    const toggle = () => {
      if (window.scrollY > 500) {
        btn.hidden = false;
        // next frame so the transition runs from the hidden state
        requestAnimationFrame(() => btn.classList.add('is-visible'));
      } else {
        btn.classList.remove('is-visible');
      }
    };
    btn.addEventListener('transitionend', () => {
      if (!btn.classList.contains('is-visible')) btn.hidden = true;
    });
    btn.addEventListener('click', () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    });
    window.addEventListener('scroll', toggle, { passive: true });
    toggle();
  }
</script>
