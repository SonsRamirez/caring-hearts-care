---
/** Testimonial — star rating, italic serif quote, avatar with initials. */
interface Props {
  quote: string;
  name: string;
  role: string;
}
const { quote, name, role } = Astro.props;
const initials = name.split(' ').slice(0, 2).map((s) => s[0]).join('');
const stars = Array.from({ length: 5 });
---

<div class="testi">
  <span class="testi__stars">
    {stars.map(() => (
      <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 7.1-1.01z"></path></svg>
    ))}
  </span>
  <p class="testi__quote">&ldquo;{quote}&rdquo;</p>
  <div class="testi__by">
    <div class="testi__avatar">{initials}</div>
    <div><div class="testi__name">{name}</div><div class="testi__role">{role}</div></div>
  </div>
</div>
