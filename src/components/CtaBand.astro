---
/** CtaBand — navy gradient conversion band (eyebrow → title → optional copy → CTAs).
 *  Primary CTA drives to the contact form. An optional secondary nav button can be passed. */
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  eyebrow = 'Start the Conversation',
  title,
  intro,
  primaryLabel = 'Get In Touch',
  primaryHref = '/contact',
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<div class="ctaband">
  <Eyebrow onDark>{eyebrow}</Eyebrow>
  <h2>{title}</h2>
  {intro && <p>{intro}</p>}
  <div class="ctaband__row">
    <Button variant="primary" size="lg" href={primaryHref}>{primaryLabel}</Button>
    {secondaryLabel && secondaryHref && (
      <Button variant="ghost-light" size="lg" iconRight="arrow-right" href={secondaryHref}>{secondaryLabel}</Button>
    )}
  </div>
</div>
