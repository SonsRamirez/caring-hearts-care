---
/**
 * Button — kit copy of the DS Button. Renders an <a> when `href` is set,
 * otherwise a <button> (e.g. form submit).
 * Variants: primary | secondary | dark | ghost-light. Sizes: sm | lg.
 */
import Icon from './Icon.astro';

interface Props {
  variant?: 'primary' | 'secondary' | 'dark' | 'ghost-light';
  size?: 'sm' | 'lg';
  icon?: string;
  iconRight?: string;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: any;
}

const {
  variant = 'primary',
  size,
  icon,
  iconRight,
  href,
  type,
  class: className,
  ...rest
} = Astro.props;

const cls = ['btn', `btn--${variant}`, size ? `btn--${size}` : '', className]
  .filter(Boolean)
  .join(' ');

const Tag = href ? 'a' : 'button';
---

<Tag class={cls} href={href} type={href ? undefined : (type ?? 'button')} {...rest}>
  {icon && <Icon name={icon} />}
  <span><slot /></span>
  {iconRight && <Icon name={iconRight} />}
</Tag>
