---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Heading from '../../components/Heading.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Button from '../../components/Button.astro';
import Icon from '../../components/Icon.astro';
import ArticleBlock from '../../components/ArticleBlock.astro';
import { articles, articleById, AUTHORS } from '../../data/articles';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.id } }));
}

const { slug } = Astro.params;
const a = articleById(slug!)!;
const author = AUTHORS[a.author];
const isToc = a.template === 'listicle' || a.template === 'guide';
const hs = a.heroStyle;

// inline hero injects the featured image as the first body block
const blocks = hs === 'inline' ? [{ type: 'image', src: a.hero, caption: a.deck }, ...a.blocks] : a.blocks;
const tocItems = a.blocks.filter((b: any) => b.type === 'numbered');
const related = articles.filter((p) => p.id !== a.id).slice(0, 3);
---

<BaseLayout active="blog" title={a.title} description={a.deck} image={a.hero}>
  <div class="article-page">
    {/* ---------- Hero ---------- */}
    {hs === 'overlay' ? (
      <section class="article-hero" style={`background-image:url(${a.hero})`}>
        <div class="article-hero__veil"></div>
        <div class="wrap wrap--narrow article-hero__inner">
          <div class="crumbs crumbs--onhero">
            <a href="/">Home</a> &nbsp;/&nbsp; <a href="/blog">Blog</a> &nbsp;/&nbsp; {a.category}
          </div>
          <span class="badge badge--gold">{a.category}</span>
          <h1 class="article-title article-title--onhero">{a.title}</h1>
          <p class="article-deck article-deck--onhero">{a.deck}</p>
          <div class="article-meta article-meta--onhero">
            <span class="art-avatar">{author.initials}</span>
            <span class="article-meta__by"><b>{author.name}</b><span>{author.role}</span></span>
            <span class="article-meta__dot"></span>
            <span class="article-meta__item"><Icon name="calendar" />{a.date}</span>
            <span class="article-meta__item"><Icon name="clock" />{a.readTime}</span>
          </div>
        </div>
      </section>
    ) : (
      <>
        {hs === 'full' && (
          <div class="article-fullhero" style={`background-image:url(${a.hero})`} role="img" aria-label={a.title}></div>
        )}
        {hs === 'video' && (
          <div class="wrap article-videohero">
            <div class="video-frame" style={`background-image:url(${a.hero})`} role="img" aria-label="Video">
              <div class="video-frame__veil"></div>
              <button class="video-frame__play" aria-label="Play video"><Icon name="play" /></button>
              {a.videoLabel && <span class="video-frame__label"><Icon name="video" />{a.videoLabel}</span>}
            </div>
          </div>
        )}
        <section class="band--tight band--white" style="padding-bottom:0;">
          <div class="wrap wrap--narrow article-head">
            <div class="crumbs crumbs--ink">
              <a href="/">Home</a> &nbsp;/&nbsp; <a href="/blog">Blog</a> &nbsp;/&nbsp; {a.category}
            </div>
            <span class="badge badge--gold" style="margin-top:1rem;">{a.category}</span>
            <h1 class="article-title">{a.title}</h1>
            <p class="article-deck">{a.deck}</p>
            <div class="article-meta">
              <span class="art-avatar">{author.initials}</span>
              <span class="article-meta__by"><b>{author.name}</b><span>{author.role}</span></span>
              <span class="article-meta__dot"></span>
              <span class="article-meta__item"><Icon name="calendar" />{a.date}</span>
              <span class="article-meta__item"><Icon name="clock" />{a.readTime}</span>
            </div>
          </div>
          {hs === 'cover' && (
            <div class="wrap"><div class="article-cover" style={`background-image:url(${a.hero})`} role="img" aria-label={a.title}></div></div>
          )}
        </section>
      </>
    )}

    {/* ---------- Body ---------- */}
    <section class="band band--cream">
      {isToc ? (
        <div class="wrap article-grid">
          {tocItems.length > 0 && (
            <aside class="article-toc">
              <span class="eyebrow">In this article</span>
              <ol>
                {tocItems.map((b: any) => (
                  <li><a href={`#sec-${b.n}`}><span>{String(b.n).padStart(2, '0')}</span>{b.h}</a></li>
                ))}
              </ol>
            </aside>
          )}
          <div class="article-body">
            {blocks.map((b: any) => <ArticleBlock b={b} />)}
            <div class="author-bio">
              <span class="art-avatar">{author.initials}</span>
              <div>
                <span class="eyebrow">Written by</span>
                <b>{author.name}</b>
                <p>{author.name === 'Nathalie Massey'
                  ? 'Founder of Caring Hearts Care, writing from years of helping families across the DMV find compassionate home care for the people they love.'
                  : 'The Caring Hearts care team shares practical guidance for families navigating home care across Potomac and the greater DC area.'}</p>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="wrap wrap--narrow article-body">
          {blocks.map((b: any) => <ArticleBlock b={b} />)}
          <div class="author-bio">
            <span class="art-avatar">{author.initials}</span>
            <div>
              <span class="eyebrow">Written by</span>
              <b>{author.name}</b>
              <p>{author.name === 'Nathalie Massey'
                ? 'Founder of Caring Hearts Care, writing from years of helping families across the DMV find compassionate home care for the people they love.'
                : 'The Caring Hearts care team shares practical guidance for families navigating home care across Potomac and the greater DC area.'}</p>
            </div>
          </div>
        </div>
      )}
    </section>

    {/* ---------- Related ---------- */}
    <section class="band band--gray">
      <div class="wrap">
        <div class="center-head"><Heading center eyebrow="Keep Reading" title="More from our blog" /></div>
        <div class="grid-3">
          {related.map((p) => (
            <a class="post" href={`/blog/${p.id}`}>
              <div class="post__photo" style={`background-image:url(${p.hero})`} role="img" aria-label={p.category}>
                <span class="post__cat">{p.category}</span>
              </div>
              <div class="post__body">
                <div class="post__meta"><Icon name="calendar" />{p.date}</div>
                <h3 class="post__title">{p.title}</h3>
                <span class="service__link">Read more<Icon name="arrow-right" /></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- CTA ---------- */}
    <section class="band band--white">
      <div class="wrap">
        <div class="ctaband">
          <Eyebrow onDark>Free, No-Obligation Consultation</Eyebrow>
          <h2>Have questions about care for your loved one?</h2>
          <div class="ctaband__row">
            <Button variant="primary" size="lg" href="/contact">Request a Free Consultation</Button>
            <Button variant="ghost-light" size="lg" iconRight="arrow-right" href="/blog">More Articles</Button>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Smooth-scroll TOC links with header offset
  document.querySelectorAll<HTMLAnchorElement>('.article-toc a').forEach((link) => {
    link.addEventListener('click', (e) => {
      const id = link.getAttribute('href')?.slice(1);
      const el = id ? document.getElementById(id) : null;
      if (el) {
        e.preventDefault();
        window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 110, behavior: 'smooth' });
      }
    });
  });
</script>
