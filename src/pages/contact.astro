---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubHero from '../components/SubHero.astro';
import Heading from '../components/Heading.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
---

<BaseLayout active="contact" title="Contact"
  description="At Caring Hearts Care, we’re always eager to connect with new clients. Submit the contact form and a care coordinator will respond promptly — the first step toward compassionate, personalized care.">
  <SubHero
    title="Get In Touch"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact Us' }]} />

  {/* Reach Out Today */}
  <section class="band band--cream">
    <div class="wrap" style="max-width:64rem;text-align:center;">
      <div class="center-head">
        <Heading center eyebrow="Reach Out Today" title="Don’t hesitate to contact us" />
      </div>
      <p style="color:var(--text-muted);line-height:var(--leading-relaxed);">At Caring Hearts Care, we’re always eager to connect with new clients and learn how we can support you and your loved ones. By simply submitting the form on our contact page, you’ll take the first step toward accessing compassionate, personalized care tailored to your needs. We’re excited about the opportunity to provide exceptional care for your loved one, and the journey begins as soon as you share your information with us. Rest assured, we’re dedicated to ensuring this process is smooth and responsive, starting with your initial inquiry. Your peace of mind and your loved one’s well-being are our top priorities, and we look forward to starting this important journey with you.</p>
    </div>
  </section>

  {/* Send Us a Message */}
  <section class="band band--white">
    <div class="wrap" style="max-width:50rem;">
      <div class="center-head">
        <Heading center eyebrow="Send Us a Message" title="Let’s start the conversation"
          intro="Submit the contact form now, and let’s start the conversation on how we can provide exceptional care for your loved one." />
      </div>

      <div class="formcard" style="margin-top:1rem;">
        <div id="form-success" class="formsuccess" hidden>
          <div class="ok"><Icon name="check" /></div>
          <h3 style="font-family:var(--font-serif);color:var(--chc-navy);font-size:1.6rem;margin:0 0 0.5rem;">Thank you<span id="success-name"></span>.</h3>
          <p style="color:var(--text-muted);margin:0 auto;max-width:36ch;">A care coordinator will reach out shortly using the contact details you provided. We’re available around the clock.</p>
          <div style="margin-top:1.6rem;">
            <Button variant="secondary" id="send-another">Send another message</Button>
          </div>
        </div>

        <form id="contact-form">
          <input type="hidden" name="access_key" value={site.web3formsKey} />
          <input type="hidden" name="from_name" value="Caring Hearts Care website" />
          {/* honeypot */}
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off"
            style="display:none;position:absolute;left:-9999px;" aria-hidden="true" />

          <div class="field-row">
            <div class="field">
              <label for="name">Name <span class="req">*</span></label>
              <input id="name" name="name" required placeholder="Name" />
            </div>
            <div class="field">
              <label for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" placeholder="Phone" />
            </div>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" placeholder="Email" />
            </div>
            <div class="field">
              <label for="subject">Subject</label>
              <input id="subject" name="subject" placeholder="Subject" />
            </div>
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Message"></textarea>
          </div>
          <p id="form-error" class="form-error" hidden></p>
          <Button variant="primary" size="lg" type="submit" id="submit-btn" class="btn-block">Submit</Button>
          <p style="font-size:0.8rem;color:var(--text-muted);text-align:center;margin-top:0.9rem;">
            <Icon name="lock" style="width:13px;height:13px;vertical-align:-2px;" /> Your information is private and never shared.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .btn-block { width: 100%; }
  .form-error {
    color: var(--color-error); font-family: var(--font-ui); font-size: 0.9rem;
    margin: 0 0 0.8rem; text-align: center;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.hidden = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorEl) errorEl.hidden = true;
    const data = new FormData(form);

    if (String(data.get('access_key')).startsWith('YOUR_')) {
      showError('This form isn’t connected yet. Please try again soon.');
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.querySelector('span')!.textContent = 'Sending…';
    }

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: data,
      });
      const json = await res.json();
      if (json.success) {
        const name = String(data.get('name') || '').trim().split(' ')[0];
        const nameEl = document.getElementById('success-name');
        if (nameEl && name) nameEl.textContent = `, ${name}`;
        form.hidden = true;
        if (success) success.hidden = false;
        success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        showError(json.message || 'Something went wrong. Please try again in a moment.');
      }
    } catch {
      showError('Network error. Please check your connection and try again.');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.querySelector('span')!.textContent = 'Submit';
      }
    }
  });

  document.getElementById('send-another')?.addEventListener('click', () => {
    form?.reset();
    if (form) form.hidden = false;
    if (success) success.hidden = true;
  });
</script>
