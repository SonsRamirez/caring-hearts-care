---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubHero from '../../components/SubHero.astro';
import Heading from '../../components/Heading.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Icon from '../../components/Icon.astro';
import { services, serviceById } from '../../data/services';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.id } }));
}

const { slug } = Astro.params;
const d = serviceById(slug!)!;
const related = services.filter((s) => s.id !== d.id).slice(0, 3);
---

<BaseLayout active="services" title={d.title} description={d.lead} image={d.image}>
  <SubHero
    title={d.title}
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Services', href: '/services' }, { label: d.title }]} />

  {/* Intro: photo + lead + includes */}
  <section class="band band--cream">
    <div class="wrap sd-intro">
      <div class="sd-media">
        <div class="sd-photo" style={`background-image:url(${d.image})`} role="img" aria-label={`${d.title} care`}>
          <span class="sd-medal"><Icon name={d.icon} /></span>
        </div>
      </div>
      <div class="sd-body">
        <Eyebrow tick>Our Services</Eyebrow>
        <p class="sd-lead">{d.lead}</p>
        <h2 class="sd-subhead">What’s included</h2>
        <div class="faq__list">
          {d.includes.map((it) => (
            <div class="faq__row"><Icon name="check" /><p>{it}</p></div>
          ))}
        </div>
        <div class="sd-cta">
          <Button variant="primary" href="/contact">Request a Free Consultation</Button>
          <Button variant="secondary" icon="phone" href="/contact">Call Us 24/7</Button>
        </div>
      </div>
    </div>
  </section>

  {/* Who it's for */}
  <section class="band--tight band--white">
    <div class="wrap">
      <div class="sd-foryou">
        <span class="sd-foryou__icon"><Icon name="heart-handshake" /></span>
        <div>
          <h3>Is this right for your family?</h3>
          <p>{d.forYou}</p>
        </div>
        <Button variant="dark" href="/contact" iconRight="arrow-right">Get a Custom Quote</Button>
      </div>
    </div>
  </section>

  {/* Related services */}
  <section class="band band--gray">
    <div class="wrap">
      <div class="center-head">
        <Heading center eyebrow="Explore More" title="Related services" />
      </div>
      <div class="grid-3">
        {related.map((r) => (
          <ServiceCard icon={r.icon} title={r.title} image={r.image}
            description={r.lead.length > 120 ? r.lead.slice(0, 117) + '…' : r.lead}
            href={`/services/${r.id}`} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
