---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubHero from '../../components/SubHero.astro';
import Heading from '../../components/Heading.astro';
import Button from '../../components/Button.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { services } from '../../data/services';
---

<BaseLayout active="services" title="Services"
  description="Caring Hearts Care provides numerous services for your loved one — personal care, meal preparation, transportation, companionship, light housekeeping, medication management, respite, post-cosmetic and dementia care across the DC, MD & VA area.">
  <SubHero
    title="Our Services"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Services' }]} />

  <section class="band band--cream">
    <div class="wrap">
      <div class="center-head">
        <Heading center eyebrow="Our Services" title="Caring Hearts Care Provides Numerous Services for Your Loved One"
          intro="If you have questions about any of the services listed below, or would like to obtain Home Care for your loved one, visit our contact page and reach out to us." />
        <div style="text-align:center;margin-top:1.4rem;">
          <Button variant="primary" href="/contact">Contact Us</Button>
        </div>
      </div>
      <div class="grid-3" style="margin-top:2.6rem;">
        {services.map((s) => (
          <ServiceCard icon={s.icon} title={s.title} description={s.description} image={s.image} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
