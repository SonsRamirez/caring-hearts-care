---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubHero from '../components/SubHero.astro';
import Heading from '../components/Heading.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';
---

<BaseLayout active="pricing" title="Pricing"
  description="At Caring Hearts Care, pricing is tailored to each client. The process begins with an initial interview to determine your specific needs, after which we provide a customized quote.">
  <SubHero
    title="Pricing Plan"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Pricing' }]} />

  <section class="band band--cream">
    <div class="wrap" style="max-width:60rem;text-align:center;">
      <div class="center-head">
        <Heading center eyebrow="Our Pricing" title="Tailored Pricing Plans for Personalized Care" />
      </div>
      <p style="color:var(--text-muted);line-height:var(--leading-relaxed);">At Caring Hearts Care, we understand that each client’s needs are unique, and our pricing plans reflect this principle. Rather than offering one-size-fits-all packages, we tailor our pricing specifically to the individual requirements of each client. This personalized approach ensures that you receive the most effective and efficient care possible, without any unnecessary costs. The process begins with an initial interview to determine your specific needs, after which we will provide a customized quote for our services. If you’re ready to explore how we can support you or your loved one, please click the yellow “Contact Us” button or fill in the form to get started. We’ll be in touch as soon as possible to set up your care and answer any questions you may have.</p>
      <div style="margin-top:1.6rem;">
        <Button variant="primary" href="/contact">Contact Us</Button>
      </div>
    </div>
  </section>

  <section class="band band--white">
    <div class="wrap" style="max-width:50rem;">
      <div class="center-head">
        <Heading center eyebrow="Send Us a Message" title="Customized Solutions to Meet Your Unique Needs" />
      </div>
      <form id="pricing-contact-form" class="formcard" style="margin-top:1rem;">
        <input type="hidden" name="access_key" value={site.web3formsKey} />
        <input type="hidden" name="from_name" value="Caring Hearts Care website — Pricing" />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;position:absolute;left:-9999px;" aria-hidden="true" />
        <div class="field-row">
          <div class="field"><label for="p-name">Name <span class="req">*</span></label><input id="p-name" name="name" required placeholder="Name" /></div>
          <div class="field"><label for="p-phone">Phone</label><input id="p-phone" name="phone" type="tel" placeholder="Phone" /></div>
        </div>
        <div class="field-row">
          <div class="field"><label for="p-email">Email</label><input id="p-email" name="email" type="email" placeholder="Email" /></div>
          <div class="field"><label for="p-subject">Subject</label><input id="p-subject" name="subject" placeholder="Subject" /></div>
        </div>
        <div class="field"><label for="p-message">Message</label><textarea id="p-message" name="message" placeholder="Message"></textarea></div>
        <p id="pricing-form-error" class="form-error" hidden></p>
        <p id="pricing-form-ok" class="form-ok" hidden>Thank you — a care coordinator will reach out shortly.</p>
        <Button variant="primary" size="lg" type="submit" id="pricing-submit" class="btn-block">Submit</Button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .btn-block { width: 100%; }
  .form-error { color: var(--color-error); text-align: center; margin: 0 0 0.8rem; }
  .form-ok { color: var(--color-success, #2e7d32); text-align: center; margin: 0 0 0.8rem; }
</style>

<script>
  const form = document.getElementById('pricing-contact-form') as HTMLFormElement | null;
  const err = document.getElementById('pricing-form-error');
  const ok = document.getElementById('pricing-form-ok');
  const btn = document.getElementById('pricing-submit') as HTMLButtonElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (err) err.hidden = true;
    const data = new FormData(form);
    if (String(data.get('access_key')).startsWith('YOUR_')) {
      if (err) { err.textContent = 'This form isn’t connected yet. Please try again soon.'; err.hidden = false; }
      return;
    }
    if (btn) { btn.disabled = true; btn.querySelector('span')!.textContent = 'Sending…'; }
    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', headers: { Accept: 'application/json' }, body: data });
      const json = await res.json();
      if (json.success) { form.reset(); if (ok) ok.hidden = false; }
      else if (err) { err.textContent = json.message || 'Something went wrong. Please try again.'; err.hidden = false; }
    } catch {
      if (err) { err.textContent = 'Network error. Please check your connection and try again.'; err.hidden = false; }
    } finally {
      if (btn) { btn.disabled = false; btn.querySelector('span')!.textContent = 'Submit'; }
    }
  });
</script>
