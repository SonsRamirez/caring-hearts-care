---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubHero from '../components/SubHero.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';

const FAQS = [
  {
    q: 'What services do you offer?',
    intro: 'We provide comprehensive non-medical home care, tailored to each individual’s needs and recovery goals:',
    items: [
      { h: 'Personal Care', p: 'Assistance with activities of daily living — bathing, grooming, dressing and toileting.' },
      { h: 'Companionship', p: 'Social interaction, conversation and emotional support to alleviate loneliness and promote well-being.' },
      { h: 'Medication Management', p: 'Reminders to take medications on schedule and assistance with administration as needed.' },
      { h: 'Meal Preparation', p: 'Planning and preparing nutritious meals tailored to dietary preferences and restrictions.' },
      { h: 'Light Housekeeping', p: 'Help with laundry, vacuuming and tidying up living spaces.' },
      { h: 'Transportation', p: 'Escorting clients to medical appointments, grocery shopping, errands and social outings.' },
      { h: 'Respite Care', p: 'Temporary relief for family caregivers, so they can take breaks and attend to their own needs.' },
      { h: 'Post-Cosmetic Care', p: 'Personalized support and care following cosmetic surgery, for a comfortable recovery at home.' },
      { h: 'Dementia Care', p: 'Specialized care for those living with Alzheimer’s or other dementias, including cognitive stimulation and behavioral management.' },
    ],
  },
  {
    q: 'How do you ensure the quality of care?',
    items: [
      { h: 'Rigorous screening & training', p: 'Background checks, reference checks and in-depth interviews, followed by comprehensive training and ongoing education.' },
      { h: 'Regular supervision & monitoring', p: 'Experienced supervisors conduct frequent home visits to observe care and address any concerns early.' },
      { h: 'Open communication & feedback', p: 'We keep open channels with clients, families and caregivers, and act on feedback to keep improving.' },
      { h: 'Quality assurance programs', p: 'Satisfaction surveys, performance evaluations and internal audits guide data-driven improvements.' },
      { h: 'Adherence to standards', p: 'We uphold all relevant regulations and best practices, with regular reviews and external audits.' },
    ],
  },
  {
    q: 'What are your caregivers’ qualifications and experience?',
    intro: 'We take great pride in the qualifications and experience of our caregivers:',
    items: [
      { h: 'Thorough background checks', p: 'Every caregiver is vetted before hire, for integrity and professionalism you can trust.' },
      { h: 'HHA certification, minimum', p: 'All caregivers hold at least a Home Health Aide (HHA) certification — skilled in daily-living support, medication management and basic healthcare procedures.' },
      { h: 'Ongoing training', p: 'Continuous education keeps caregivers current on best practices and emerging trends in home care.' },
      { h: 'Licensed-nurse assessments', p: 'Initial assessments are conducted by licensed nurses, who build a personalized care plan for each client.' },
    ],
  },
  {
    q: 'How do you match caregivers with clients?',
    intro: 'We match on compatibility — not just skills, but on a personal level too:',
    items: [
      { h: 'Skills & experience', p: 'We match the caregiver’s expertise to each client’s specific needs, from personal care to dementia or post-surgery recovery.' },
      { h: 'Personality & interests', p: 'We pair clients with caregivers who share similar interests, fostering real connection and companionship.' },
      { h: 'Cultural & linguistic background', p: 'We consider cultural and language fit to ensure clear communication and a comfortable, inclusive environment.' },
      { h: 'Availability & scheduling', p: 'Round-the-clock, part-time or occasional — we find a schedule that works for both client and caregiver.' },
      { h: 'Feedback & preferences', p: 'We solicit input throughout the relationship and adjust as needed to keep everyone satisfied.' },
    ],
  },
];
---

<BaseLayout active="faq" title="FAQ"
  description="Answers to common questions about Caring Hearts Care — our services, how we ensure quality, caregiver qualifications, and how we match caregivers with your family.">
  <SubHero
    title="Frequently asked questions"
    intro="Top questions, answered here. Got more? Our team is always happy to help — just reach out."
    crumbs={[{ label: 'Home', href: '/' }, { label: 'FAQ' }]} />

  <section class="band band--cream">
    <div class="wrap wrap--narrow">
      <div class="faq__group">
        {FAQS.map((f, i) => (
          <div class={`faq ${i === 0 ? 'faq--open' : ''}`}>
            <button class="faq__q" aria-expanded={i === 0 ? 'true' : 'false'}>
              <span>{f.q}</span>
              <span class="faq__toggle">
                <span class="faq__plus"><Icon name="plus" /></span>
                <span class="faq__minus"><Icon name="minus" /></span>
              </span>
            </button>
            <div class="faq__a">
              <div class="faq__a-inner">
                {f.intro && <p class="faq__intro">{f.intro}</p>}
                <div class="faq__list">
                  {f.items.map((it) => (
                    <div class="faq__row">
                      <Icon name="check" />
                      <p><b>{it.h}</b> — {it.p}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="faq__cta">
        <h3>Still have questions?</h3>
        <p>We’re here to help you navigate every step. Reach out and we’ll answer anything.</p>
        <Button variant="primary" href="/contact">Contact Us</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Accordion expand/collapse driven by the faq--open class */
  .faq__a { max-height: 0; }
  .faq--open .faq__a { max-height: 1600px; }
  .faq__toggle :global(svg) {
    width: 22px; height: 22px; color: var(--chc-gold-deep); flex: none;
    background: var(--chc-gold-tint); border-radius: 999px; padding: 4px; box-sizing: content-box;
  }
  .faq__plus, .faq__minus { display: inline-flex; }
  .faq__minus { display: none; }
  .faq--open .faq__plus { display: none; }
  .faq--open .faq__minus { display: inline-flex; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq');
      const isOpen = item?.classList.contains('faq--open');
      // close all
      document.querySelectorAll('.faq').forEach((el) => el.classList.remove('faq--open'));
      document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      // open this one if it was closed
      if (!isOpen) {
        item?.classList.add('faq--open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
